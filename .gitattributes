# Normalize every text file to LF in the repo — kills the Windows
# "LF will be replaced by CRLF" churn/warnings. Editors keep LF on checkout.
* text=auto eol=lf

# Explicit source/config types (belt-and-suspenders)
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsonc text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.svg  text eol=lf
*.sql  text eol=lf

# Binary assets — never touch line endings
*.woff2 binary
*.woff  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.webp  binary
