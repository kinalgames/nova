{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nova-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-20",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  // Smart Placement: run near the upstream LLM APIs (US) instead of the
  // user's nearest colo — Anthropic/OpenAI 403-block egress from some Asian
  // colos ("Request not allowed" / unsupported_country_region_territory),
  // which hit real users chatting from VN. Static assets stay on the edge.
  "placement": { "mode": "smart" },

  // ── local development (wrangler dev, no --env) ──────────────────────────
  // The web client runs on Vite (:5173) locally, so no assets here; bindings
  // use wrangler's local sqlite. Secrets come from .dev.vars.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nova",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "drizzle"
    }
  ],
  "durable_objects": {
    "bindings": [{ "name": "USER_STORE", "class_name": "UserStore" }]
  },
  // DO migrations are shared across environments (top-level only)
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["UserStore"] }],
  "analytics_engine_datasets": [{ "binding": "USAGE", "dataset": "nova_usage_local" }],
  // B1 — attachment bytes (metadata lives in D1 `attachment`); local dev uses
  // miniflare's simulated R2, the name below never touches a real bucket
  "r2_buckets": [{ "binding": "ATTACH", "bucket_name": "nova-attachments-local" }],
  // B3 abuse shields — per-colo approximate counters, keyed by IP (src/ratelimit.ts).
  // namespace_id must be unique per limiter AND per env so counters never mix.
  "ratelimits": [
    { "name": "RL_AUTH", "namespace_id": "1001", "simple": { "limit": 10, "period": 60 } },
    { "name": "RL_CHAT", "namespace_id": "1002", "simple": { "limit": 30, "period": 60 } },
    { "name": "RL_API", "namespace_id": "1003", "simple": { "limit": 120, "period": 60 } }
  ],

  // ── deployed environments ───────────────────────────────────────────────
  // ONE Worker per env serves BOTH the built web app (static assets, SPA
  // fallback) and the API (run_worker_first routes) — same-origin, so
  // session cookies and fetches need no CORS gymnastics. Secrets per env via
  // `wrangler secret put NAME --env <env>`:
  //   BETTER_AUTH_SECRET · CREDENTIALS_KEY · GEMINI_OAUTH_CLIENT_ID/SECRET ·
  //   GOOGLE_CLIENT_ID/SECRET · (GITHUB_CLIENT_ID/SECRET khi có) ·
  //   (AE_SQL_TOKEN + CF_ACCOUNT_ID cho /v1/usage read-back)
  "env": {
    "dev": {
      "name": "nova-dev",
      "observability": { "enabled": true },
      "vars": {
        "BETTER_AUTH_URL": "https://nova-dev.kinalgames.workers.dev",
        "WEB_ORIGIN": "https://nova-dev.kinalgames.workers.dev",
        // Anthropic rejects some Workers-egress colos (403 “Request not
        // allowed”, intermittent by placement) — route via AI Gateway “nova”,
        // Cloudflare's first-party proxy; BYOK headers pass through unchanged
        "ANTHROPIC_BASE_URL": "https://gateway.ai.cloudflare.com/v1/346d7d74298e7e60d4071adc7b3c6c7c/nova/anthropic"
      },
      "assets": {
        "directory": "../web/dist",
        "not_found_handling": "single-page-application",
        "run_worker_first": ["/v1/*", "/api/*", "/healthz"]
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "nova-dev",
          "database_id": "54de4c43-d754-4a98-96cb-a6dd31ca4014",
          "migrations_dir": "drizzle"
        }
      ],
      "durable_objects": {
        "bindings": [{ "name": "USER_STORE", "class_name": "UserStore" }]
      },
      "analytics_engine_datasets": [{ "binding": "USAGE", "dataset": "nova_usage_dev" }],
      "r2_buckets": [{ "binding": "ATTACH", "bucket_name": "nova-attachments-dev" }],
      "ratelimits": [
        { "name": "RL_AUTH", "namespace_id": "2001", "simple": { "limit": 10, "period": 60 } },
        { "name": "RL_CHAT", "namespace_id": "2002", "simple": { "limit": 30, "period": 60 } },
        { "name": "RL_API", "namespace_id": "2003", "simple": { "limit": 120, "period": 60 } }
      ]
    },
    "production": {
      "name": "nova",
      "observability": { "enabled": true },
      // nova.kinal.co = custom domain (gắn qua Dashboard → Worker → Domains;
      // wrangler deploy KHÔNG đụng vào custom domains). OAuth consoles cần
      // redirect URI https://nova.kinal.co/api/auth/callback/{google,github}.
      // workers.dev giữ làm legacy origin: email login chạy, social dồn về
      // canonical (popup khác origin không chia sẻ được localStorage token).
      "vars": {
        "BETTER_AUTH_URL": "https://nova.kinal.co",
        "WEB_ORIGIN": "https://nova.kinal.co",
        "TRUSTED_ORIGINS_EXTRA": "https://nova.kinalgames.workers.dev",
        // see the dev block — stable path around Anthropic's Workers-egress 403
        "ANTHROPIC_BASE_URL": "https://gateway.ai.cloudflare.com/v1/346d7d74298e7e60d4071adc7b3c6c7c/nova/anthropic"
      },
      "assets": {
        "directory": "../web/dist",
        "not_found_handling": "single-page-application",
        "run_worker_first": ["/v1/*", "/api/*", "/healthz"]
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "nova",
          "database_id": "65f66b6c-891e-4074-960d-6cc4a3a44d4f",
          "migrations_dir": "drizzle"
        }
      ],
      "durable_objects": {
        "bindings": [{ "name": "USER_STORE", "class_name": "UserStore" }]
      },
      "analytics_engine_datasets": [{ "binding": "USAGE", "dataset": "nova_usage" }],
      "r2_buckets": [{ "binding": "ATTACH", "bucket_name": "nova-attachments" }],
      "ratelimits": [
        { "name": "RL_AUTH", "namespace_id": "3001", "simple": { "limit": 10, "period": 60 } },
        { "name": "RL_CHAT", "namespace_id": "3002", "simple": { "limit": 30, "period": 60 } },
        { "name": "RL_API", "namespace_id": "3003", "simple": { "limit": 120, "period": 60 } }
      ]
    }
  }
}
